# Maintainer: HybridUofA <hybriduofa@users.noreply.github.com>

pkgname=casters-compendium
pkgver=0.1.3
pkgrel=1
pkgdesc="Desktop deck builder for Caster Chronicles"
arch=('x86_64')
url="https://github.com/HybridUofA/casters-compendium"
license=('custom:unspecified')
options=('!debug')
depends=(
  'glibc'
  'libglvnd'
  'libx11'
  'wayland'
)
makedepends=(
  'git'
  'go'
  'libxcursor'
  'libxi'
  'libxinerama'
  'libxkbcommon'
  'libxrandr'
  'mesa'
)
_source_fragment=${CASTERS_COMPENDIUM_SOURCE_FRAGMENT:-tag=v$pkgver}
source=(
  "$pkgname::git+$url.git#$_source_fragment"
  'casters-compendium.desktop'
  'casters-compendium.1'
  'copyright'
)
sha256sums=(
  'SKIP'
  '6e10e82c918302b93b94590a3cfbe3b2e3f23e013a8902dd63b812f05012fe6d'
  'ffe1510fdd666f8d67a325f0b79ecd3ffde2d15e530ebf3e28fb26d30d9af768'
  '78f4b2e062fbe745a7e256efad0d0cc9d2d27395ec9e3cd8fb6cb712e0d01ef8'
)

check() {
  cd "$pkgname"
  go test -tags migrated_fynedo ./...
}

build() {
  cd "$pkgname"
  go build \
    -tags migrated_fynedo \
    -buildmode=pie \
    -trimpath \
    -ldflags='-s -w' \
    -o CastersCompendium \
    ./cmd/deckbuilder
}

package() {
  install -Dm755 \
    "$pkgname/CastersCompendium" \
    "$pkgdir/usr/bin/casters-compendium"
  install -Dm644 \
    'casters-compendium.desktop' \
    "$pkgdir/usr/share/applications/casters-compendium.desktop"
  install -Dm644 \
    "$pkgname/data/images/shadow.png" \
    "$pkgdir/usr/share/pixmaps/casters-compendium.png"
  install -Dm644 \
    "$pkgname/README.md" \
    "$pkgdir/usr/share/doc/casters-compendium/README.md"
  install -Dm644 \
    'casters-compendium.1' \
    "$pkgdir/usr/share/man/man1/casters-compendium.1"
  install -Dm644 \
    'copyright' \
    "$pkgdir/usr/share/licenses/casters-compendium/LICENSE"
}
